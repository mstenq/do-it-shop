# When adding additional environment variables, the schema in "/src/env.mjs"
# should be updated accordingly.

# Drizzle
# Get the Database URL from the "prisma" dropdown selector in PlanetScale. 
# Change the query params at the end of the URL to "?ssl={"rejectUnauthorized":true}"
# DATABASE_TENANT_URL='libsql://do-it-shop-mstenq.turso.io'
DATABASE_TENANT_URL='file:db/do-it-shop.sqlite'
DATABASE_AUTH_TOKEN=""


TURSO_APP_ORGANIZATION="<<github-username>>"
TURSO_API_URL="https://api.turso.tech"
TURSO_API_TOKEN=""

# Auth Secret
# You can generate a new secret on the command line with:
# openssl rand -base64 32
AUTH_SECRET=""
